# Pylint configuration for G25 Telegram Bot

[MASTER]
jobs=4
persistent=yes
load-plugins=

[MESSAGES CONTROL]
disable=
    missing-docstring,
    too-many-arguments,
    too-many-instance-attributes,
    too-few-public-methods,

[FORMAT]
max-line-length=120
indent-string='    '

[DESIGN]
max-attributes=10
max-args=6

[VARIABLES]
dummy-variables-rgx=_+$|^unused_

[SIMILARITIES]
min-similarity-lines=5
ignore-comments=yes
ignore-docstrings=yes

[LOGGING]
logging-format-style=old
